              "});",
              "",
              "pm.test('returns predictable validation error shape', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.have.nested.property('error.code', 'bad_request');",
              "  pm.expect(json).to.have.nested.property('error.message', 'Validation failed');",
              "  pm.expect(json.error.details).to.be.an('object');",
              "});"
            ]
          }
        }
