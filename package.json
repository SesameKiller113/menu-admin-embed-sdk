{
  "name": "menu-admin-embed-sdk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/menu-admin",
    "apps/restaurant-site",
    "packages/menu-admin-sdk"
  ],
  "scripts": {
    "dev": "concurrently -k -n backend,menu-admin,restaurant-site -c cyan,green,magenta \"npm run backend:start\" \"npm run menu-admin:dev\" \"npm run restaurant-site:dev\"",
    "backend:start": "npm --workspace @menu-admin-embed-sdk/backend run start",
    "backend:dev": "npm --workspace @menu-admin-embed-sdk/backend run dev",
    "backend:smoke": "npm --workspace @menu-admin-embed-sdk/backend run smoke",
    "backend:typecheck": "npm --workspace @menu-admin-embed-sdk/backend run typecheck",
    "menu-admin:dev": "npm --workspace @menu-admin-embed-sdk/menu-admin run dev",
    "menu-admin:build": "npm --workspace @menu-admin-embed-sdk/menu-admin run build",
    "menu-admin:preview": "npm --workspace @menu-admin-embed-sdk/menu-admin run preview",
    "menu-admin:test": "npm --workspace @menu-admin-embed-sdk/menu-admin run test",
    "menu-admin:typecheck": "npm --workspace @menu-admin-embed-sdk/menu-admin run typecheck",
    "restaurant-site:dev": "npm --workspace @menu-admin-embed-sdk/restaurant-site run dev",
    "restaurant-site:build": "npm --workspace @menu-admin-embed-sdk/restaurant-site run build",
    "restaurant-site:preview": "npm --workspace @menu-admin-embed-sdk/restaurant-site run preview",
    "restaurant-site:typecheck": "npm --workspace @menu-admin-embed-sdk/restaurant-site run typecheck",
    "sdk:build": "npm --workspace @menu-admin-embed-sdk/sdk run build",
    "sdk:typecheck": "npm --workspace @menu-admin-embed-sdk/sdk run typecheck",
    "test": "npm run backend:smoke && npm run menu-admin:test && npm run restaurant-site:build && npm run sdk:build"
  },
  "devDependencies": {
    "concurrently": "^9.2.4"
  }
}
